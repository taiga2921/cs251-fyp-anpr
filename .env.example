# AI ANPR — example environment configuration (M9)
# Copy to .env and adjust values.

# --- Source ---
ANPR_SOURCE=rtsp
ANPR_RTSP_URL=rtsp://user:password@camera-ip:554/stream1
ANPR_VIDEO_PATH=samples/videos/document_6177158287369184218.mp4
ANPR_IMAGE_PATH=samples/images/photo_6177158287829176211_w.jpg
ANPR_CAMERA_INDEX=0

# --- Models ---
# Model files are NOT committed or auto-downloaded. Place .pt files manually.
ANPR_VEHICLE_MODEL=models/vehicle/yolo11s.pt
ANPR_PLATE_MODEL=models/plate/license-plate-finetune-v1s.pt
ANPR_DEVICE=cpu
ANPR_VEHICLE_CONF=0.35
ANPR_PLATE_CONF=0.25

# --- OCR (M4+) ---
ANPR_OCR_ENGINE=paddleocr
ANPR_OCR_LANG=en
ANPR_OCR_PREPROCESS=true
ANPR_OCR_SCALE=2.0
ANPR_MIN_OCR_CONFIDENCE=0.30

# --- Tracking / vote buffer (M5) ---
ANPR_TARGET_FPS=3
ANPR_TRACK_IOU_THRESHOLD=0.3
ANPR_TRACK_EXPIRY_SECONDS=2.0
ANPR_EARLY_FINALIZE_MIN_VOTES=3
ANPR_EARLY_FINALIZE_MIN_CONFIDENCE=0.90
ANPR_MIN_PLATE_VOTES=2

# --- Events / evidence (M6) ---
ANPR_DUPLICATE_COOLDOWN_SECONDS=10

# --- Backend (M7/M8/M9) ---
ANPR_BACKEND_ENABLED=false
ANPR_BACKEND_BASE_URL=http://localhost:8000/api
ANPR_BACKEND_EMAIL=
ANPR_BACKEND_PASSWORD=
ANPR_BACKEND_CAMERA_ID=
ANPR_BACKEND_TOKEN_CACHE=.cache/backend_token.json
ANPR_BACKEND_QUEUE_FILE=.cache/backend_queue.jsonl
ANPR_BACKEND_RETRY_LIMIT=3
ANPR_BACKEND_TIMEOUT_SECONDS=10

# --- Evidence delivery (M9/M10) ---
# upload = recommended for backend/cloud deployment; AI uploads evidence files to Laravel storage/app/anpr.
# metadata = local development only; sends file paths and requires Laravel ANPR_IMAGE_ROOTS to read the AI runs directory.
ANPR_EVIDENCE_MODE=upload
ANPR_EVIDENCE_RETENTION_DAYS=0
ANPR_RUNS_DIR=runs
ANPR_SAVE_LOCAL_EVIDENCE=true
ANPR_DELETE_LOCAL_AFTER_UPLOAD=false
